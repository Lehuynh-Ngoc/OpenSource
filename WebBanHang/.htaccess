RewriteEngine On
RewriteBase /

# Nếu yêu cầu là Project1/... hãy chuyển hướng vật lý vào thư mục đó
# Hoặc đơn giản là để Apache tự tìm vào thư mục Project1 nếu nó tồn tại
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^Project1/(.*)$ Project1/index.php?url=$1 [QSA,L]

# Redirect root sang Project1
RewriteRule ^$ Project1/ [L,R=301]